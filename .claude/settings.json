{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(go *)",
      "Bash(goreleaser *)",
      "Bash(gofmt *)",
      "Bash(golint *)",
      "Bash(govulncheck *)",
      "Read",
      "Glob",
      "Grep"
    ],
    "deny": [
      "Bash(git push --force *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Bash executed'",
            "once": true
          }
        ]
      }
    ]
  },
  "cleanupPeriodDays": 30
}
